<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TARIFFUPDATE</title>
    <link rel="stylesheet" href="css/app.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
</head>

<body>
    <header>
        <logo class="navbar">
            <img class="logoheader" src="images/logo.png" alt="PowerPilot Logo">
        </logo>
        <div class="navbar">
            <a class="navclick" href="/">Home</a>
            <a class="navclick" href="/config">Config</a>
            <a class="navclick" href="/dashboard">Dashboard</a>
            <a class="navclick" id="navclickon" href="/tariffupdate">Tariff Update</a>
        </div>
    </header>

    <div class="tariff-header">
        <h1>Tariff Update Window</h1>
    </div>

    <div class="workspaceT">
        <form action="/tariffupdate" method="post">
            <div class="tariff-column">
                <% for(let i=0;i<12;i++){ %>
                    <label for="time<%=i%>">Tariff during <%=i%>:00-<%=i+1%>:00</label>
                    <input type="number" min="1" id="time<%=i%>" name="time<%=i%>">

                    <% } %>
            </div>
            <div class="tariff-column">
                <% for(let i=12;i<24;i++){ %>
                    <label for="time<%=i%>">Tariff during <%=i%>:00-<%=i+1%>:00</label>
                    <input type="number" min="1" id="time<%=i%>" name="time<%=i%>">

                    <% } %>
            </div>
            <button>Submit</button>
        </form>
    </div>


    <footer>
        <div>
            <p class="footertext">Copyright © 2026 ProjectPowerPilot</p>
        </div>
    </footer>

</body>

</html>